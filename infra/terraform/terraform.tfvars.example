# Copia este archivo a  terraform.tfvars  y rellena tus valores.
# terraform.tfvars está ignorado por Git (no subas datos sensibles).
region                 = "us-east-2"
az                     = "us-east-2a"
project                = "filmstars"
admin_cidr             = "TU_IP_PUBLICA/32" # curl ifconfig.me
ssh_pub_key_path       = "~/.ssh/filmstars_deploy.pub"
k3s_instance_type      = "t3.large"
registry_instance_type = "t3.small"
develop_instance_type  = "t3.medium"
