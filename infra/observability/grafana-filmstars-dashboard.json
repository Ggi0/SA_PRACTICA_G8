{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["filmstars", "practica6"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "FilmStars — Observabilidad Práctica 6",
  "uid": "filmstars-p6",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "CPU por pod (ns filmstars)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"filmstars\",container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memoria por pod (ns filmstars)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"filmstars\",container!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Targets Prometheus (UP/DOWN)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{job=~\"ec2-node-exporter|filmstars-api\"}", "legendFormat": "{{job}} {{instance}}", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Boletos validados por minuto",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(filmstars_tickets_validated_total[1m])) * 60",
          "legendFormat": "boletos/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests del API Gateway (rate 1m)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(filmstars_http_requests_total[1m]))",
          "legendFormat": "status {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU de las EC2 (node_exporter)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",group=\"aws-ec2\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
