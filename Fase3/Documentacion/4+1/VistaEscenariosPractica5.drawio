        <mxCell id="R0wtVXsqgFRmbySFWfQi-10" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontFamily=Arial;fontSize=16;fontColor=#333333;align=center;verticalAlign=middle;" value="CDU 004 Reserva y&lt;br&gt;compra de boletos" vertex="1">
